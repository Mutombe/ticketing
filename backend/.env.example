# Copy to .env and fill in. Never commit the real .env.
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=tikiti
DO_SPACES_REGION=sfo3
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
USE_SPACES=False

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Paynow — leave blank to use the simulated instant-paid flow.
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RESULT_URL=https://ticketboy-backend.onrender.com/api/payments/result/
PAYNOW_RETURN_URL=https://ticketboy.co.zw/tickets

FRONTEND_ORIGINS=http://localhost:5173
